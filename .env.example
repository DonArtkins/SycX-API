# ============================================================
# SycX-API — Environment Configuration Template
# ============================================================
#
# INSTRUCTIONS:
#   1. Copy this file to `.env` in the project root:
#        cp .env.example .env
#   2. Replace every placeholder value (YOUR_*) with your actual credentials.
#   3. NEVER commit the `.env` file — it is already in .gitignore
#
# ============================================================


# ============================================================
# FLASK CONFIGURATION
# ============================================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000


# ============================================================
# API CONFIGURATION
# ============================================================
# SECRET_KEY — used for session signing. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECRET_KEY_HERE
API_TITLE=SycX-API
API_VERSION=v1
RATE_LIMIT=1000
RATE_LIMIT_PERIOD=15


# ============================================================
# MODEL CONFIGURATION
# ============================================================
MODEL_PATH=app/models/trained_models
MAX_MEMORY_MB=1280
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
MALLOC_TRIM_THRESHOLD_=100000


# ============================================================
# API KEYS & SERVICES
# ============================================================
# Hugging Face — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_TOKEN_HERE

# Unsplash — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=YOUR_UNSPLASH_ACCESS_KEY_HERE

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Google Generative AI — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE


# ============================================================
# CLOUDINARY CONFIGURATION
# ============================================================
# Cloudinary — https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME_HERE
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY_HERE
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET_HERE